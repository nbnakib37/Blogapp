<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_blog"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_blog"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleBlog">

        <activity android:name=".DetailActivity" />
        <activity android:name=".AddPostActivity" />
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver android:name=".PostCreatedReceiver" android:exported="false" />
        <service android:name=".BlogIntentService" android:exported="false" />
    </application>
</manifest>
